    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "grid_gap", "min": 10, "max": 60, "default": 30, "unit": "px", "label": "Grid Gap" },
    { "type": "range", "id": "pt", "label": "Padding Top", "min": 0, "max": 100, "default": 50, "unit": "px" },
    { "type": "range", "id": "pb", "label": "Padding Bottom", "min": 0, "max": 100, "default": 50, "unit": "px" },
    { "type": "header", "content": "Final Link Tab" },
    { "type": "text", "id": "view_all_text", "label": "Link Tab Text", "default": "VIEW ALL", "info": "Appears as the last tab." },
    { "type": "url", "id": "view_all_link", "label": "Link Tab URL", "info": "Optional: Makes the last tab redirect to a page." }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "PROJECT NAME" },
        { "type": "text", "id": "sub_text", "label": "sub_text", "default": "Testimony" },
        { "type": "text", "id": "group", "label": "Category (Tab Names)", "default": "Featured, Restaurant", "info": "Separate multiple categories with a comma." },
