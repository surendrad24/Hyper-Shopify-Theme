{{ 'cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

  
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Wishlist Specific Styles */
  .wishlist-item-row { border-bottom: 1px solid #eee; }
  .cart-item__media {
    width: 100px;
    height: 100px;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .cart-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    border: none;
  }
  .btn-remove-wishlist { 
    color: #000; 
    cursor: pointer; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    width: 30px; 
    height: 30px; 
  }
  .add-to-cart-btn-wishlist { 
    margin-top: 10px; 
    font-size: 13px; 
    padding: 8px 15px; 
    transition: all 0.2s ease-in-out;
  }
  .add-to-cart-btn-wishlist:hover {
    background-color: #f7f7f7 !important;
    border: 1px solid #000;
  }
  .add-to-cart-btn-wishlist:hover .btn__text {
    color: #000 !important; 
  }
  .add-to-cart-btn-wishlist.btn-view-cart {
    background-color: #000;
    color: #fff;
  }
  .add-to-cart-btn-wishlist.btn-view-cart:hover {
    background-color: #f7f7f7 !important;
    border: 1px solid #000 !important;
    color: #000 !important;
  }
  .wishlist-variant-select {
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 13px;
    margin-top: 5px;
    width: 100%;
    max-width: 200px;
  }
  .btn-remove-wishlist svg { transition: transform 0.3s ease; }
  .btn-remove-wishlist:hover svg { transform: rotate(180deg); }
{%- endstyle -%}

<div class="cart section-{{ section.id }}-padding">
  <div class="section__container page-width">
    
    <div class="cart__header">
      <h1 class="cart__title h1 inline-flex gap-2" style="margin-top:24px;">
        {{ section.settings.heading }} <span id="wishlist-count-display"></span>
      </h1>
    </div>

    <main-cart class="block md:flex items-stretch gap-10">
      <div class="cart__inner flex-1">
        <div id="wishlist-loader" class="text-center padding-20" style="font-weight:bold;">{{ 'Loading Your Favourites...' }}</div>
        
        <table role="table" class="w-full" id="wishlist-table" style="display: none;">
          <thead class="hidden md:table-header-group">
            <tr class="text-left border-b">
              <th class="h6 pb-4" colspan="2">Product</th>
              <th class="h6 pb-4 text-right">Price</th>
            </tr>
          </thead>
          <tbody id="wt-grid-items"></tbody>
        </table>

        <div id="empty-wishlist" style="display:none;" class="cart__empty text-center flex flex-col gap-10">
           <h2 class="h1">{{ section.settings.empty_text }}</h2>
           <a class="btn btn--primary self-center" style="margin-top:16px;" href="{{ section.settings.continue_shopping_link }}">
            <span class="btn__text">Continue Shopping</span>
          </a>
        </div>
      </div>

      <div class="cart__footer flex flex-col" style="width: 350px;">
        <div class="sticky-element border p-6 blocks-radius bg-light">
          <div class="grid gap-6">
            <div class="totals flex justify-between items-center h5">
              <span>Items in Wishlist</span>
              <span id="sidebar-count">0</span>
            </div>
            <p class="text-sm text-subtext">Prices shown exclude shipping and GST until checkout.</p>
            
            <button id="add-all-btn" class="btn btn--primary w-full" onclick="addAllToCart()">
              <span class="btn__text">Add All to Cart</span>
            </button>

            <a href="/collections/all" class="btn btn--secondary w-full">
              <span class="btn__text">Add More Items</span>
            </a>
          </div>
        </div>
      </div>
    </main-cart>
  </div>
</div>

<script>
const STOREFRONT_TOKEN = '{{ section.settings.storefront_token }}'; 
const STORE_URL = `${window.location.protocol}//${window.location.host}`;

async function fetchProductByHandle(handle) {
  const query = `
    query {
      product(handle: "${handle}") {
        title
        handle
        variants(first: 20) {
          edges {
            node {
              id
              title
              availableForSale
              price { amount }
              image { src }
            }
          }
        }
      }
    }`;

  try {
    const res = await fetch(`${STORE_URL}/api/2023-10/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': STOREFRONT_TOKEN,
      },
      body: JSON.stringify({ query }),
    });
    const json = await res.json();
    return json.data ? json.data.product : null;
  } catch (err) {
    console.error(`Error fetching ${handle}:`, err);
    return null;
  }
}

async function displayWishlist() {
  const container = document.getElementById('wt-grid-items');
  const table = document.getElementById('wishlist-table');
  const loader = document.getElementById('wishlist-loader');
  const emptyMsg = document.getElementById('empty-wishlist');
  const countDisplay = document.getElementById('wishlist-count-display');
  const sidebarCount = document.getElementById('sidebar-count');

  let wishlist = (JSON.parse(localStorage.getItem('wishlist')) || []).filter(h => h && h.trim() !== "");

  if (wishlist.length === 0) {
    if(loader) loader.style.display = 'none';
    if(table) table.style.display = 'none';
    if(emptyMsg) emptyMsg.style.display = 'block';
    if(countDisplay) countDisplay.innerText = '(0)';
    if(sidebarCount) sidebarCount.innerText = '0';
    const addAllBtn = document.getElementById('add-all-btn');
    if(addAllBtn) addAllBtn.disabled = true;
    return;
  }

  try {
    const promises = wishlist.map(handle => fetchProductByHandle(handle));
    const results = await Promise.all(promises);
    const products = results.filter(product => product !== null);

    let html = '';
    let validCount = 0;

    products.forEach(product => {
      validCount++;
      const variants = product.variants.edges;
      const firstV = variants[0].node;
      const isAvailable = firstV.availableForSale;

      html += `
        <tr class="cart-item wishlist-item-row" id="card-${product.handle}">
          <td class="cart-item__product py-6">
            <div class="flex items-start md:items-center gap-4 md:gap-6">
              <a onclick="removeFromWishlist('${product.handle}')" class="btn-remove-wishlist" title="Remove" style="cursor:pointer;">
                 <svg width="18" height="18" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" >
                    <path d="M12.5 3.5L3.5 12.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3.5 3.5L12.5 12.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                 </svg>
                 
              </a>
              

              <a class="cart-item__media blocks-radius " href="/products/${product.handle}" style="width: 100px;">
                <img src="${firstV.image ? firstV.image.src : ''}" loading="lazy" width="100" height="100" style="object-fit: contain;">
              </a>

              <div class="cart-item__product--info flex flex-col items-start gap-1">
                 <a href="/products/${product.handle}" class="cart-item__title text-pcard-title reversed-link font-bold">${product.title}</a>
                 
                 ${variants.length > 1 ? `
                    <select id="variant-${product.handle}" onchange="updateVariantStatus('${product.handle}')" class="wishlist-variant-select">
                      ${variants.map(v => `
                        <option value="${v.node.id}" data-available="${v.node.availableForSale}" data-price="${v.node.price.amount}">
                          ${v.node.title}
                        </option>`).join('')}
                    </select>
                 ` : `<input type="hidden" id="variant-${product.handle}" value="${firstV.id}" data-available="${isAvailable}">`}

                <button id="btn-${product.handle}" 
                        onclick="addToCart('${product.handle}')" 
                        class="btn btn--primary add-to-cart-btn-wishlist" 
                        ${!isAvailable ? 'disabled' : ''}>
                  <span class="btn__text">
                    ${isAvailable ? 'Add to Cart' : 'Out of Stock'}
                  </span>
                </button>
              </div>
            </div>
          </td>
          <td class="cart-item__total text-right py-6">
            <div class="price font-body-bolder">
              <span id="price-${product.handle}">$${parseFloat(firstV.price.amount).toFixed(2)}</span> ex GST
            </div>
          </td>
        </tr>`;
    });

    if(loader) loader.style.display = 'none';
    
    if(validCount > 0) {
      if(table) table.style.display = 'table';
      if(container) container.innerHTML = html;
      if(countDisplay) countDisplay.innerText = `(${validCount})`;
      if(sidebarCount) sidebarCount.innerText = validCount;
      if(emptyMsg) emptyMsg.style.display = 'none';
    } else {
      if(table) table.style.display = 'none';
      if(emptyMsg) emptyMsg.style.display = 'block';
    }

  } catch (error) {
    console.error("Wishlist Error:", error);
    if(loader) loader.style.display = 'none';
  }
}

function updateVariantStatus(handle) {
  const select = document.getElementById(`variant-${handle}`);
  const selectedOption = select.options[select.selectedIndex];
  const btn = document.getElementById(`btn-${handle}`);
  const priceEl = document.getElementById(`price-${handle}`);
  
  const isAvailable = selectedOption.getAttribute('data-available') === 'true';
  const price = selectedOption.getAttribute('data-price');

  priceEl.innerHTML = `$${parseFloat(price).toFixed(2)}`;

  if (isAvailable) {
    btn.innerHTML = '<span class="btn__text">Add to Cart</span>';
    btn.disabled = false;
    btn.classList.remove('btn--disabled');
  } else {
    btn.innerHTML = '<span class="btn__text">Out of Stock</span>';
    btn.disabled = true;
    btn.classList.add('btn--disabled');
  }
}

// Function to update cart count in header ONLY (no messages)
function updateCartCountSilently() {
  fetch(window.Shopify.routes.root + 'cart.js')
    .then(res => res.json())
    .then(cart => {
      // Update all cart count elements quietly
      const countElements = document.querySelectorAll(
        '.cart-count-bubble, .header__cart-count, #cart-icon-bubble span, .cart-count, [data-cart-count]'
      );
      
      countElements.forEach(el => {
        if (el) {
          const countSpan = el.querySelector('span') || el;
          countSpan.textContent = cart.item_count;
          
          // Show/hide based on count
          if (cart.item_count > 0) {
            countSpan.classList.remove('hidden');
            countSpan.style.display = '';
          } else if (cart.item_count === 0) {
            countSpan.classList.add('hidden');
          }
        }
      });
      
      // Update the cart object in theme silently (no events that trigger messages)
      if (window.FoxTheme && window.FoxTheme.theme && window.FoxTheme.theme.cart) {
        window.FoxTheme.theme.cart = cart;
      }
      
      // Update Shopify's cart object if it exists
      if (window.Shopify && window.Shopify.theme) {
        window.Shopify.theme.cart = cart;
      }
    })
    .catch(err => console.error('Cart count update error:', err));
}

function addToCart(handle) {
  const btn = document.getElementById(`btn-${handle}`);
  const btnText = btn.querySelector('.btn__text');
  
  // If button already says "View Cart", redirect to cart page
  if (btnText.innerText === 'View Cart') {
    window.location.href = '/cart';
    return;
  }
  
  const variantId = document.getElementById(`variant-${handle}`).value;
  const numericId = variantId.includes('/') ? variantId.split('/').pop() : variantId;

  // Show "Adding..." while adding to cart
  btnText.innerText = 'Adding...';
  btn.disabled = true;

  fetch(window.Shopify.routes.root + 'cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: [{ id: numericId, quantity: 1 }] })
  })
  .then(response => {
    if (!response.ok) {
      throw new Error('Failed to add to cart');
    }
    return response.json();
  })
  .then(cartData => {
    // Re-enable button and change text to "View Cart"
    btn.disabled = false;
    btnText.innerText = 'View Cart';
    btn.classList.add('btn-view-cart');
    
    // Update cart count SILENTLY (no messages)
    updateCartCountSilently();
  })
  .catch((err) => {
    console.error('Add to cart error:', err);
    btnText.innerText = 'Add to Cart';
    btn.disabled = false;
    btn.classList.remove('btn-view-cart');
  });
}

async function addAllToCart() {
  const addAllBtn = document.getElementById('add-all-btn');
  const originalText = addAllBtn.querySelector('.btn__text')?.innerText || addAllBtn.innerText;
  
  addAllBtn.querySelector('.btn__text').innerText = 'Adding All...';
  addAllBtn.disabled = true;

  const inputs = document.querySelectorAll('[id^="variant-"]');
  const itemsToAdd = [];

  inputs.forEach(input => {
    let variantId, isAvailable;
    if (input.tagName === 'SELECT') {
      const selected = input.options[input.selectedIndex];
      variantId = selected.value;
      isAvailable = selected.getAttribute('data-available') === 'true';
    } else {
      variantId = input.value;
      isAvailable = input.getAttribute('data-available') === 'true' || input.getAttribute('data-available') === true;
    }
    if (isAvailable) {
       const numericId = variantId.includes('/') ? variantId.split('/').pop() : variantId;
       itemsToAdd.push({ id: numericId, quantity: 1 });
    }
  });

  if (itemsToAdd.length === 0) {
    addAllBtn.querySelector('.btn__text').innerText = 'No items available';
    setTimeout(() => { 
      addAllBtn.querySelector('.btn__text').innerText = originalText; 
      addAllBtn.disabled = false; 
    }, 2000);
    return;
  }

  try {
    const res = await fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: itemsToAdd })
    });

    if (res.ok) {
      const cartData = await res.json();
      
      // Update cart count SILENTLY (no messages)
      updateCartCountSilently();
      
      // Change all "Add to Cart" buttons to "View Cart" for available items
      document.querySelectorAll('.add-to-cart-btn-wishlist').forEach(btn => {
        if (!btn.disabled && btn.querySelector('.btn__text').innerText === 'Add to Cart') {
          btn.querySelector('.btn__text').innerText = 'View Cart';
          btn.classList.add('btn-view-cart');
        }
      });
      
      addAllBtn.querySelector('.btn__text').innerText = 'Done! Redirecting...';
      
      setTimeout(() => { window.location.href = '/cart'; }, 1000);
    } else {
      throw new Error('Failed to add all items');
    }
  } catch (err) {
    console.error('Add all to cart error:', err);
    addAllBtn.querySelector('.btn__text').innerText = 'Try Again';
    setTimeout(() => { 
      addAllBtn.querySelector('.btn__text').innerText = originalText; 
      addAllBtn.disabled = false; 
    }, 2000);
  }
}

function removeFromWishlist(handle) {
  let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];
  wishlist = wishlist.filter(item => item !== handle);
  localStorage.setItem('wishlist', JSON.stringify(wishlist));
  displayWishlist();
  window.dispatchEvent(new Event('wishlistUpdated'));
}

document.addEventListener('DOMContentLoaded', displayWishlist);
</script>

{% schema %}
{
  "name": "Wishlist Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty Wishlist Text",
      "default": "Your wishlist is empty"
    },
    {
      "type": "url",
      "id": "continue_shopping_link",
      "label": "Continue Shopping Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "storefront_token",
      "label": "Storefront Access Token",
      "default": "5f395ab46a1694ae427aabb187924b57",
      "info": "Found in Shopify Admin > Settings > Apps > Develop Apps"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Wishlist Page"
    }
  ]
}
{% endschema %}