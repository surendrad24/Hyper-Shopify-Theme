{{ 'component-multicolumn-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile | plus: 0
-%}

{% style %}
  .section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .multicolumn__items {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat({{ columns_mobile }}, 1fr);
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }} .multicolumn__items {
      grid-template-columns: repeat({{ columns_desktop }}, 1fr);
    }
  }

  .section-{{ section.id }} .multicolumn-card {
    display: flex;
    flex-direction: column;
    height: 100%; 
    background: #fff;
  }

  .section-{{ section.id }} .card-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 4px;
  }

  .section-{{ section.id }} .card-image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; 
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .section-{{ section.id }} .multicolumn-card:hover img {
    transform: scale(1.08);
  }

  .section-{{ section.id }} .multicolumn-card__info {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 15px 0;
  }

  .section-{{ section.id }} {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 12px;
    color: #2b2b2b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.4em; 
  }
  .card-title {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    color: #2b2b2b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.4em; 
  }

  .section-{{ section.id }} .button-group {
    margin-top: auto; 
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 10px;
  }

    /* 4. Button Design */
  .shop-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 38px; 
    background: #000000;
    color: #f7f7f7;
    border-radius: 50rem; 
    border: 1px solid black;
    cursor: pointer;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    z-index: 1;
    line-height: 1; 
  }

  .shop-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: #ffffff;
    transition: left 0.4s ease;
    z-index: -1;
  }

  .shop-button:hover::before {
    left: 0;
  }

  .shop-button:hover {
    color: #000000;
  }

  .section-{{ section.id }} .btn-download {
    width: 44px;
    height: 44px;
    border: 1.5px solid #a0a0a0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .section-{{ section.id }} .btn-download:hover {
    border-color: #000;
    color: #000;
    background: #f8f8f8;
  }
{% endstyle %}

<div class="section-{{ section.id }} section--padding">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="inline-richtext {{ section.settings.heading_size }} mb-8">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="multicolumn__items">
      {%- for block in section.blocks -%}
        <div class="multicolumn-card" {{ block.shopify_attributes }}>
          
          {%- comment -%} Card Image {%- endcomment -%}
          <div class="card-image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg bg-gray-100' }}
            {%- endif -%}
          </div>

          {%- comment -%} Card Content {%- endcomment -%}
          <div class="multicolumn-card__info">
            {%- if block.settings.title != blank -%}
              <h3 class="card-title">{{ block.settings.title }}</h3>
            {%- endif -%}

            <div class="button-group">
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link }}" class=" shop-button">
                  {{ block.settings.button_label }}
                </a>
              {%- endif -%}

              {%- if block.settings.download_link != blank -%}
                <a href="{{ block.settings.download_link }}" download target="_blank" rel="noopener noreferrer" class="btn-download" title="Download PDF">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Catalog Download Grid",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "default": "Our Catalogues", "label": "Heading" },
    { "type": "select", "id": "heading_size", "label": "Heading Size", "default": "h2", "options": [ { "value": "h2", "label": "Small" }, { "value": "h1", "label": "Large" } ] },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 5, "step": 1, "default": 4, "label": "Columns on Desktop" },
    { "type": "select", "id": "columns_mobile", "label": "Columns on Mobile", "options": [ { "value": "1", "label": "1" }, { "value": "2", "label": "2" } ], "default": "1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 36 }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Catalog Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Catalog Cover Image" },
        { "type": "inline_richtext", "id": "title", "default": "Catalog Title", "label": "Heading" },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "View" },
        { "type": "url", "id": "button_link", "label": "View Link" },
        { "type": "url", "id": "download_link", "label": "Download Link (PDF File URL)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Catalog Download Grid",
      "blocks": [ { "type": "column" }, { "type": "column" }, { "type": "column" }, { "type": "column" } ]
    }
  ]
}
{% endschema %}

