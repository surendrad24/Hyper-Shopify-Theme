{% schema %}
{
  "name": "Google Maps",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Us Here"
    },
    {
      "type": "textarea",
      "id": "map_embed_url_1",
      "label": "Google Maps Embed URL – Location 1"
    },
    {
      "type": "textarea",
      "id": "map_embed_url_2",
      "label": "Google Maps Embed URL – Location 2"
    },
    {
      "type": "range",
      "id": "map_height",
      "label": "Map Height (px)",
      "min": 300,
      "max": 700,
      "step": 50,
      "default": 450
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width maps",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Google Maps "
    }
  ]
}
{% endschema %}  