{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop
-%}

{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  .shop-by-brand-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding: 0 10px;
  }

  .section-{{ section.id }} .shop-by-brand-title {
     font-family:'instrument sans';
     font-size: {{ section.settings.heading_size }}px;
     color: {{ section.settings.heading_color }};
     font-weight: 700;
     margin: 0;
  }

  /* --- UPDATED: SHOP ALL LINK + ARROW + DYNAMIC SCHEMA --- */
  .shop-all-link {
    font-family:'instrument sans';
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
    color: {{ section.settings.shop_all_color }};
    font-size: 15px;
    font-weight: {{ section.settings.shop_all_weight }};
    transition: opacity 0.3s ease;
    position: relative;
  }

  .shop-all-link-text {
    position: relative;
    padding-bottom: 2px;
  }

  /* Smooth Underline Hover Effect */
  .shop-all-link-text::after {
    content: '';
    position: absolute;
    width: 0;
    height: 1px;
    bottom: 0;
    left: 0;
    background-color: currentColor;
    transition: width 0.3s ease-in-out;
  }

  .shop-all-link:hover .shop-all-link-text::after {
    width: 100%;
  }

  .shop-all-link svg {
    width: 12px;
    height: 14px;
    transition: transform 0.3s ease;
  }

  .shop-all-link:hover svg {
    transform: translateX(3px);
  }

  /* --- CAROUSEL STYLES --- */
  .brand-carousel-{{ section.id }} {
    display: flex;
    gap: 15px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 10px 0;
  }

  .brand-carousel-{{ section.id }}::-webkit-scrollbar { display: none; }

  .brand-item-custom {
    flex: 0 0 calc(100% / {{ columns_desktop }} - 12px);
    min-width: 220px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .brand-img-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 15px;
  }

  .brand-img-custom {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .brand-item-custom:hover .brand-img-custom { transform: scale(1.05); }

  .brand-info-text { display: inline-block; width: fit-content; }

  .brand-name-custom {
    font-family: 'instrument sans';
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 600;
    color: #000;
    position: relative;
    padding-bottom: 4px;
    display: inline-block;
  }

  .brand-name-custom::after {
    content: '';
    position: absolute;
    width: 0;
    height: 1px;
    bottom: 0;
    left: 0;
    background-color: #000;
    transition: width 0.3s ease-in-out;
  }

  .brand-item-custom:hover .brand-name-custom::after { width: 100%; }

  .progress-and-controls-{{ section.id }} { display: flex; align-items: center; gap: 20px; margin-top: 24px; }
  .carousel-progress-{{ section.id }} { flex: 1; height: 1.5px; background: #e0e0e0; position: relative; }
  .carousel-progress-fill-{{ section.id }} { position: absolute; top: 0; left: 0; height: 100%; width: 0%; background: #000; transition: width 0.2s ease; }
  .carousel-controls-{{ section.id }} { display: flex; gap: 8px; }
  .carousel-button-{{ section.id }} { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #d1d1d1; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #000; }
  .carousel-button-{{ section.id }}:disabled { opacity: 0.3; cursor: not-allowed; }

  @media screen and (max-width: 749px) {
    .shop-by-brand-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .brand-item-custom { flex: 0 0 70%; }
    .section-{{ section.id }} .shop-by-brand-title { font-size: 24px; }
  }
{% endstyle %}

<div class="section-{{ section.id }}">
  <div class="page-width">
    
    <div class="shop-by-brand-header">
      <h2 class="shop-by-brand-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="shop-all-link">
           <span class="shop-all-link-text">{{ section.settings.view_all_label }}</span>
           <svg class="icon icon-caret-right" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M7.5 3.75L13.75 10L7.5 16.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
        </a>
      {%- endif -%}
    </div>

    <div class="brand-carousel-wrapper">
      <div class="brand-carousel-{{ section.id }}" id="Slider-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign collection = collections[block.settings.brand_collection]
            if block.settings.brand_image != blank
              assign display_image = block.settings.brand_image
            else
              assign display_image = collection.featured_image
            endif
            if block.settings.custom_title != blank
              assign display_title = block.settings.custom_title
            else
              assign display_title = collection.title | default: "Brand Name"
            endif
          -%}
          
          <a href="{{ collection.url | default: '#' }}" class="brand-item-custom" {{ block.shopify_attributes }}>
            <div class="brand-img-container">
              {% if display_image != blank %}
                <img src="{{ display_image | img_url: '600x600' }}" alt="{{ display_title }}" class="brand-img-custom" loading="lazy">
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'brand-img-custom' }}
              {% endif %}
            </div>

            <div class="brand-info-text">
              <span class="brand-name-custom">{{ display_title }}</span>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {% if section.settings.show_arrows %}
        <div class="progress-and-controls-{{ section.id }}">
          <div class="carousel-progress-{{ section.id }}"><div class="carousel-progress-fill-{{ section.id }}" id="Fill-{{ section.id }}"></div></div>
          <div class="carousel-controls-{{ section.id }}">
            <button class="carousel-button-{{ section.id }}" id="Prev-{{ section.id }}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18L9 12L15 6"/></svg></button>
            <button class="carousel-button-{{ section.id }}" id="Next-{{ section.id }}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6L15 12L9 18"/></svg></button>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function () {
  const init = () => {
    const slider = document.getElementById('Slider-{{ section.id }}');
    const prevBtn = document.getElementById('Prev-{{ section.id }}');
    const nextBtn = document.getElementById('Next-{{ section.id }}');
    const progressFill = document.getElementById('Fill-{{ section.id }}');
    if (!slider) return;
    function updateUI() {
      const maxScroll = slider.scrollWidth - slider.clientWidth;
      const scrollLeft = slider.scrollLeft;
      if (prevBtn) prevBtn.disabled = scrollLeft <= 5;
      if (nextBtn) nextBtn.disabled = scrollLeft >= maxScroll - 5;
      if (progressFill && maxScroll > 0) {
        progressFill.style.width = ((scrollLeft / maxScroll) * 100) + '%';
      }
    }
    prevBtn?.addEventListener('click', () => slider.scrollBy({ left: -slider.clientWidth / 2, behavior: 'smooth' }));
    nextBtn?.addEventListener('click', () => slider.scrollBy({ left: slider.clientWidth / 2, behavior: 'smooth' }));
    slider.addEventListener('scroll', updateUI);
    window.addEventListener('resize', updateUI);
    updateUI();
  };
  document.addEventListener('DOMContentLoaded', init);
  if (Shopify.designMode) { document.addEventListener('shopify:section:load', init); }
})();
</script>

{% schema %}
{
  "name": "Shop by Brand Clean",
  "settings": [
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading Size",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Brand"
    },
    {
      "type": "header",
      "content": "Shop All Link Settings"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Link Label",
      "default": "Shop All Brands"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "shop_all_color",
      "label": "Link Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "shop_all_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Link Font Size",
      "default": 14
    },
    {
      "type": "select",
      "id": "shop_all_weight",
      "label": "Link Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Card Font Settings"
    },
    {
      "type": "font_picker",
      "id": "card_font",
      "label": "Collection Name Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 14,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Collection Name Size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Columns on Desktop"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "collection",
          "id": "brand_collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (Overrides Collection Name)",
          "info": "Useful if you didn't select a collection or want to use a different name."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Brand Clean",
      "blocks": [ { "type": "brand" }, { "type": "brand" }, { "type": "brand" }, { "type": "brand" }, { "type": "brand" } ]
    }
  ]
}
{% endschema %}