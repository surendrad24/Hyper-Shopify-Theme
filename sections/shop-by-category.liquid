<style>
.collection-grid {
  width: 100%;
}

.collection-grid__container {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 1.5rem;
}

.collection-grid__wrapper {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1.5rem;
  width: 100%;
}

/* Collection Card */
.collection-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  background-color: #e5e7eb;
  border-radius: 0;
}

.collection-card__link {
  display: block;
  width: 100%;
  height: 100%;
  text-decoration: none;
  color: inherit;
  position: relative;
}

.collection-card__image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background-color: #f3f4f6;
}


.collection-card__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  border: 1px solid lightgray;
  outline: none;
  z-index: 1;
}

/* Dark overlay on hover */
.collection-card__link:hover .collection-card__image-wrapper::before {
  opacity: 0.2;
}

.collection-card__image-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #000;
  opacity: 0;
  z-index: 3;
  transition: opacity 0.3s ease;
}

/* Placeholder - Fixed to prevent broken image icons */
.collection-card__placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  z-index: 1;
}

/* FIXED: Hide broken image icons and ensure placeholder shows when image fails */
.collection-card__image[src*="no-image-available"],
.collection-card__image:not([src]),
.collection-card__image[src=""] {
  display: none;
}

/* Ensure placeholder is shown when image fails to load */
.collection-card__placeholder {
  display: none;
}

.collection-card__image-wrapper:has(.collection-card__image:not([src])) .collection-card__placeholder,
.collection-card__image-wrapper:has(.collection-card__image[src=""]) .collection-card__placeholder,
.collection-card__image-wrapper:has(.collection-card__image[src*="no-image-available"]) .collection-card__placeholder,
.collection-card__image-wrapper:not(:has(.collection-card__image)) .collection-card__placeholder {
  display: flex;
}

.collection-card__placeholder-icon {
  width: 60px;
  height: 60px;
  margin-bottom: 12px;
  opacity: 0.25;
}

.collection-card__placeholder-icon svg {
  width: 100%;
  height: 100%;
  fill: #9ca3af;
}

.collection-card__placeholder-text {
  font-size: 0.875rem;
  color:#000000;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Overlay - Strong gradient for text visibility */
.collection-card__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.4) 50%,
    rgba(0, 0, 0, 0.85) 100%
  );
  z-index: 2;
  pointer-events: none;
  opacity: 1;
}

/* FIXED: Ensure overlay is always visible */
.collection-grid-{{ section.id }} .collection-card__overlay {
  opacity: 1 !important;
}

/* Content - Ensure it's always on top */
.collection-card__content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 1.5rem;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.collection-card__title {
  font-family: var(--font-heading-family);
  font-style: var(--font-heading-style);
  font-weight: var(--font-heading-weight);
  font-size: 1.25rem;
  line-height: 1.3;
  letter-spacing: 0.02em;
  margin: 0;
  color: #ffffff;
  position: relative;
  z-index: 10;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

.collection-card__icon {
  flex-shrink: 0;
  width: 2.5rem;
  height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #000000;
  color: #ffffff;
  position: relative;
  z-index: 10;
  transition: all 0.3s ease;
}

/* FIXED: Arrow turns white on hover (it's already white, so ensure contrast) */
.collection-card__link:hover .collection-card__icon {
  background-color: #ffffff;
  color: #000000;
}

.collection-card__icon svg {
  width: 1.125rem;
  height: 1.125rem;
  stroke: currentColor;
  stroke-width: 2;
}

/* Responsive Design */
@media screen and (max-width: 1199px) {
  .collection-grid__wrapper {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media screen and (max-width: 989px) {
  .collection-grid__wrapper {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .collection-card__content {
    padding: 1.2rem;
  }

  .collection-card__title {
    font-size: 1.125rem;
  }

  .collection-card__icon {
    width: 2.25rem;
    height: 2.25rem;
  }

  .collection-card__icon svg {
    width: 1rem;
    height: 1rem;
  }
}

@media screen and (max-width: 749px) {
  .collection-grid__wrapper {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .collection-grid__container {
    padding: 0 1rem;
  }

  .collection-card__content {
    padding: 1rem;
  }

  .collection-card__title {
    font-size: 1rem;
  }

  .collection-card__icon {
    width: 2rem;
    height: 2rem;
  }

  .collection-card__icon svg {
    width: 0.875rem;
    height: 0.875rem;
  }
}

@media screen and (max-width: 549px) {
  .collection-grid__wrapper {
    grid-template-columns: repeat(1, 1fr);
  }
}

/* Color Scheme Support */
.collection-grid.color-background-1,
.collection-grid.color-background-2,
.collection-grid.color-inverse {
  background-color: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.collection-grid.gradient {
  background: rgb(var(--color-background));
}

/* Focus and Accessibility */
.collection-card__link:focus-visible {
  outline: 0.2rem solid rgba(var(--color-foreground), 0.5);
  outline-offset: 0.3rem;
}

.collection-card__link:focus:not(:focus-visible) {
  outline: 0;
}

/* No other hover effects as requested */
.collection-card__link {
  transition: none;
}

/* Dynamic styles from section settings */
.collection-grid-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.collection-grid-{{ section.id }} .collection-card__title {
  color: {{ section.settings.text_color }};
}

/* Custom overlay if set - FIXED: Ensure it works */
{% if section.settings.use_custom_overlay %}
.collection-grid-{{ section.id }} .collection-card__overlay {
  background: {{ section.settings.overlay_color }} !important;
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }} !important;
}
{% endif %}
</style>

<div class="collection-grid collection-grid-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-grid__container page-width">
    <div class="collection-grid__wrapper">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = collections[block.settings.collection]
          assign collection_url = collection.url | default: '#'
          assign collection_title = block.settings.title | default: collection.title | default: 'Collection'
          assign has_image = false
          
          if collection.image
            assign has_image = true
            assign image = collection.image
          elsif collection.products.first and collection.products.first.featured_image
            assign has_image = true
            assign image = collection.products.first.featured_image
          endif
        -%}

        <div class="collection-card" {{ block.shopify_attributes }}>
          <a href="{{ collection_url }}" class="collection-card__link" {% if collection_url == '#' %}onclick="return false;" style="cursor: default;"{% endif %}>
            <div class="collection-card__image-wrapper">
              {%- if has_image -%}
                <img
                  srcset="
                    {%- if image.width >= 165 -%}{{ image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if image.width >= 360 -%}{{ image | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if image.width >= 535 -%}{{ image | image_url: width: 535 }} 535w,{%- endif -%}
                    {%- if image.width >= 750 -%}{{ image | image_url: width: 750 }} 750w,{%- endif -%}
                    {%- if image.width >= 1000 -%}{{ image | image_url: width: 1000 }} 1000w,{%- endif -%}
                    {{ image | image_url }} {{ image.width }}w
                  "
                  src="{{ image | image_url: width: 750 }}"
                  sizes="(min-width: 1400px) 260px, (min-width: 990px) calc((100vw - 130px) / 5), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 30px) / 2)"
                  alt="{{ image.alt | default: collection_title | escape }}"
                  class="collection-card__image"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  onerror="this.style.display='none';"
                >
                
                <div class="collection-card__overlay"></div>
                
                <!-- Hidden placeholder that shows if image fails to load -->
                <div class="collection-card__placeholder">
                  <div class="collection-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                      <path d="M21 15L16 10L8 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 13L9 16L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="collection-card__placeholder-text">No Image</span>
                </div>
              {%- else -%}
                <!-- Show placeholder when no image is available -->
                <div class="collection-card__placeholder">
                  <div class="collection-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                      <path d="M21 15L16 10L8 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 13L9 16L3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="collection-card__placeholder-text">No Image</span>
                </div>
                <div class="collection-card__overlay"></div>
              {%- endif -%}
              
              <div class="collection-card__content">
                <h3 class="collection-card__title">
                  {{ collection_title | escape }}
                </h3>
                <div class="collection-card__icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Overlay Settings"
    },
    {
      "type": "checkbox",
      "id": "use_custom_overlay",
      "label": "Use custom overlay",
      "info": "Enable to customize overlay color and opacity",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Custom overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },

      ]
    }
  ],
  "presets": [
    {
      "name": "Category collection grid",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}