    { "type": "color", "id": "card_border_color_hover", "label": "Border Hover", "default": "#000000" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "card_title_size", "min": 14, "max": 30, "step": 1, "label": "Title Size", "default": 18 },
    { "type": "select", "id": "card_title_weight", "label": "Title Weight", "options": [{"value":"400","label":"Regular"},{"value":"700","label":"Bold"}], "default": "700" },
    { "type": "color", "id": "card_title_color", "label": "Title Color", "default": "#1a1a1a" },
    { "type": "checkbox", "id": "show_product_count", "label": "Show Product Count", "default": true },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View All", "default": true },
    { "type": "text", "id": "view_all_text", "label": "Button Text", "default": "VIEW ALL" },
    { "type": "header", "content": "Spacing" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
{ "type": "range", "id": "padding_top","label":"padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom","label":"padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60 }
  ],
  "presets": [{ "name": "Hyper Custom Grid" }]
}
{% endschema %} {% endcomment %}


