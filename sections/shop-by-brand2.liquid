      const indexB = parseInt(b.getAttribute('data-index'));
      
      switch(sortValue) {
        case 'alphabet-asc': return titleA.localeCompare(titleB);
        case 'alphabet-desc': return titleB.localeCompare(titleA);
        case 'price-asc': return priceA - priceB;
        case 'price-desc': return priceB - priceA;
        case 'date-asc': return dateA - dateB;
        case 'date-desc': return dateB - dateA;
        case 'count-asc': return countA - countB;
        case 'count-desc': return countB - countA;
        case 'featured': return indexA - indexB;
        default: return indexA - indexB;
      }
    });

    cards.forEach(card => grid.appendChild(card));
  }

  if(searchInput) searchInput.addEventListener('input', updateGallery);
  if(sortSelect) sortSelect.addEventListener('change', updateGallery);
});
</script>

