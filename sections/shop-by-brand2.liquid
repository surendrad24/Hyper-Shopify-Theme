    { "type": "color", "id": "heading_color", "label": "Color", "default": "#000000" },
    { "type": "header", "content": "Search Settings" },
    { "type": "text", "id": "search_placeholder", "label": "Placeholder", "default": "Search brands..." },
    { "type": "text", "id": "no_results_text", "label": "No Results Message", "default": "No brands found matching your search." },
    { "type": "header", "content": "Card Style" },
    { "type": "range", "id": "grid_desktop", "min": 2, "max": 6, "step": 1, "label": "Cards per row", "default": 4 },
    { "type": "range", "id": "card_corner_radius", "min": 0, "max": 40, "step": 1, "unit": "px", "label": "Corner Radius", "default": 16 },
